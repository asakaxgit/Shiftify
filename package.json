{
  "name": "shiftify",
  "version": "0.1.0",
  "type": "module",
  "imports": { "#*": "./src/*" },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "export": "tsx src/cli/export.ts",
    "import": "tsx src/cli/import.ts",
    "auth": "tsx src/cli/auth.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint ./src",
    "format": "biome format ./src --write",
    "check": "biome check ./src",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "codegen": "graphql-codegen"
  },
  "dependencies": {
    "@shopify/shopify-api": "^13.0.0",
    "chalk": "^5.3.0",
    "dotenv": "^16.3.1",
    "fs-extra": "^11.2.0",
    "graphql": "^16.13.0",
    "minimist": "^1.2.8",
    "p-limit": "^6.1.0",
    "winston": "^3.18.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@graphql-codegen/cli": "^6.1.2",
    "@graphql-codegen/client-preset": "^5.2.3",
"@types/fs-extra": "^11.0.4",
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.0.0"
  }
}

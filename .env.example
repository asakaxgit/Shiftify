SOURCE_SHOP=your-source.myshopify.com
SOURCE_ACCESS_TOKEN=shpat_xxx
DEST_SHOP=your-dest.myshopify.com
DEST_ACCESS_TOKEN=shpat_xxx
SHOPIFY_CLIENT_ID=your_app_client_id
SHOPIFY_CLIENT_SECRET=your_app_client_secret
SOURCE_TYPE=shopify
# When SOURCE_TYPE=matrixify-xlsx, path to the XLSX file (or leave empty to use a file in DATA_DIR)
# SOURCE_XLSX_PATH=/path/to/Export.xlsx
API_VERSION=2026-01
SHOPIFY_PLAN=plus
BATCH_SIZE=250
CONCURRENCY=10
DATA_DIR=./data
MAPS_DIR=./maps
# Optional: when importing collections, publish to "all" channels (default: Online Store only)
# COLLECTION_PUBLISH_CHANNELS=all

# Integration tests: copy .env.test.integration.example → .env.test.integration

# Copy this file to .env.test.integration and fill in your dev store credentials.
# SOURCE_SHOP and DEST_SHOP must point to the SAME dev store.
# The test pipeline is: truncate → seed → export → truncate → import → verify

SOURCE_SHOP=your-dev.myshopify.com
SOURCE_ACCESS_TOKEN=shpat_xxx
DEST_SHOP=your-dev.myshopify.com
DEST_ACCESS_TOKEN=shpat_xxx
SOURCE_TYPE=shopify
API_VERSION=2026-01
SHOPIFY_PLAN=standard
BATCH_SIZE=250
CONCURRENCY=5
DATA_DIR=./data
MAPS_DIR=./maps

# Safety gate — both vars must be set or truncateShop will refuse to run.
INTEGRATION_TEST_SHOP=your-dev.myshopify.com
SAFE_SHOP_PATTERN=dev
